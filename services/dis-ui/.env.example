# dis-ui environment variables (Vite). Copy to .env.local for local overrides.
# .env files are git-ignored; this example is the committed documentation.

# Which dis-ui-server data source the UI uses.
#   fixture (default) - inlined fixture data, no backend call (slice 19).
#   real              - calls dis-ui-server (wired but not implemented in slice 19).
# Any value other than "real" is treated as "fixture".
VITE_DIS_UI_SERVER_MODE=fixture

# Base URL of dis-ui-server. Unused in fixture mode; REQUIRED in real mode.
# Never hardcode localhost in source; configure it here per environment.
# VITE_DIS_UI_SERVER_BASE_URL=https://dis-ui-server.example

# --- Auth -------------------------------------------------------------------
# Auth mode. 'auth0' (default) uses the Auth0 SPA SDK with in-memory tokens.
# 'dev-stub' enables the local persona picker (/dev/login) and a localStorage
# stub token. dev-stub is selectable ONLY in a dev build (import.meta.env.DEV)
# AND when set here explicitly; a production build always uses auth0 regardless
# of this value, so the stub can never ship.
VITE_AUTH_MODE=auth0

# Auth0 SPA configuration (the existing Cortex Auth0 application). These are
# PUBLIC values - a SPA client id is not a secret - but they are env-driven so
# they are never hardcoded in source and can differ per environment. The
# redirect_uri is window.location.origin at runtime (http://localhost:5173 in
# dev), a registered callback on the application; it is not set here.
VITE_AUTH0_DOMAIN=sevyn8.us.auth0.com
VITE_AUTH0_CLIENT_ID=ie7g0amymdpQNUtnyix11fxYtoBKXdJg
VITE_AUTH0_AUDIENCE=https://api.cortex.sevyn8.com
